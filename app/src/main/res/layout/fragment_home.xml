<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/homes">

    <Button
        android:id="@+id/goToStartButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Go to Start"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/soldierHouseButton"
        android:layout_width="110dp"
        android:layout_height="70dp"
        android:text="Soldier"
        android:alpha="0.8"
        android:backgroundTint="#7E57C2"
        android:textColor="#FFFFFF"
        android:layout_marginTop="110dp"
        android:layout_marginStart="120dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/scientistHouseButton"
        android:layout_width="110dp"
        android:layout_height="70dp"
        android:text="Scientist"
        android:alpha="0.8"
        android:backgroundTint="#7E57C2"
        android:textColor="#FFFFFF"
        android:layout_marginTop="240dp"
        android:layout_marginStart="210dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/engineerHouseButton"
        android:layout_width="110dp"
        android:layout_height="70dp"
        android:text="Engineer"
        android:alpha="0.8"
        android:backgroundTint="#7E57C2"
        android:textColor="#FFFFFF"
        android:layout_marginTop="400dp"
        android:layout_marginStart="95dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/dragonHouseButton"
        android:layout_width="110dp"
        android:layout_height="70dp"
        android:text="Dragon"
        android:alpha="0.8"
        android:backgroundTint="#7E57C2"
        android:textColor="#FFFFFF"
        android:layout_marginTop="560dp"
        android:layout_marginStart="205dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/doctorHouseButton"
        android:layout_width="110dp"
        android:layout_height="70dp"
        android:text="Doctor"
        android:alpha="0.8"
        android:backgroundTint="#7E57C2"
        android:textColor="#FFFFFF"
        android:layout_marginTop="720dp"
        android:layout_marginStart="105dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>