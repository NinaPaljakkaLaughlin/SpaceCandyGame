<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/memberName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/memberType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type: Soldier"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/memberStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="XP: 0 | Energy: 12/12"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/memberHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Missions: 0 | Training: 0"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/memberSpecial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Special: None"
            android:textSize="14sp"
            android:textColor="#388E3C"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>